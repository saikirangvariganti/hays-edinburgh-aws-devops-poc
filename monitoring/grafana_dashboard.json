{
  "id": null,
  "uid": "hays-devops-eks",
  "title": "Hays DevOps EKS Cluster Overview",
  "tags": ["kubernetes", "eks", "aws", "devops"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Cluster CPU Utilization",
      "type": "gauge",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)",
          "legendFormat": "CPU Usage %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          },
          "max": 100,
          "min": 0
        }
      }
    },
    {
      "id": 2,
      "title": "Cluster Memory Utilization",
      "type": "gauge",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "Memory Usage %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 75},
              {"color": "red", "value": 90}
            ]
          },
          "max": 100,
          "min": 0
        }
      }
    },
    {
      "id": 3,
      "title": "Pod Count by Namespace",
      "type": "bargauge",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "count by (namespace) (kube_pod_info{namespace=~'production|staging|monitoring'})",
          "legendFormat": "{{namespace}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 20}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Application Request Rate",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total{namespace='production'}[5m])",
          "legendFormat": "{{method}} {{status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 5,
      "title": "Application P95 Latency",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace='production'}[5m])) by (le))",
          "legendFormat": "P95 Latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "red", "value": 2.0}
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Node Status",
      "type": "table",
      "gridPos": {"x": 0, "y": 16, "w": 24, "h": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "kube_node_status_condition{condition='Ready',status='true'}",
          "legendFormat": "{{node}}",
          "instant": true
        }
      ],
      "options": {
        "showHeader": true
      }
    }
  ]
}
